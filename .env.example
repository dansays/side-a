# --- AI ---
ANTHROPIC_API_KEY=sk-ant-...
# Model used for both vision identification and intro scripting.
ANTHROPIC_MODEL=claude-opus-4-8

# --- ElevenLabs TTS ---
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=...
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# --- Last.fm scrobbling (optional; leave blank to disable) ---
# API key + secret: https://www.last.fm/api/account/create
LASTFM_API_KEY=
LASTFM_API_SECRET=
# Obtain once with: python scripts/lastfm_auth.py  (after setting the two above)
LASTFM_SESSION_KEY=
# Fallback per-track length (seconds) when Discogs has no duration.
DEFAULT_TRACK_SECONDS=210

# --- Discogs ---
# Personal access token from https://www.discogs.com/settings/developers
DISCOGS_TOKEN=...
DISCOGS_USERNAME=your_discogs_username
# Discogs REQUIRES a descriptive, unique User-Agent.
DISCOGS_USER_AGENT=SideA/0.1 +https://github.com/you/side-a

# --- Home Assistant ---
# IMPORTANT: in Docker, use Home Assistant's IP, not an mDNS name. Containers
# can't resolve ".local" addresses, so http://homeassistant.local:8123 fails with
# a NameResolutionError and every HA call (light, camera, playback) aborts. Use
# the IP (e.g. http://192.168.1.58:8123) and give HA a DHCP reservation so it
# doesn't change. The .local form is fine only for local-dev outside Docker.
HA_BASE_URL=http://192.168.1.58:8123
# Long-lived access token (HA profile -> Security -> Long-lived access tokens)
HA_TOKEN=...
HA_CAMERA_ENTITY=camera.album_cam
HA_MEDIA_PLAYER_ENTITY=media_player.homepod
# HA script driving the WLED strip; called with action=flash|processing|done.
# Defaults to script.side_a_lights, so you only need to set this to override it.
HA_LIGHTS_SCRIPT=script.side_a_lights

# --- App ---
# Base URL the HomePod uses to fetch the intro MP3 from this app. Prefer the
# host's IP with a DHCP reservation (e.g. http://192.168.1.40:8099) over a
# ".local" name. Must NOT be localhost — the HomePod fetches this over the LAN.
APP_PUBLIC_BASE_URL=http://192.168.1.40:8099
APP_PORT=8099
# Seconds to wait after the flash light turns on before grabbing the snapshot.
FLASH_DELAY_SECONDS=1.5
# Where SQLite db, thumbnails, and generated mp3s live.
# LOCAL DEV ONLY: this ./data default is for running uvicorn directly on your Mac.
# In Docker/on the NAS, docker-compose.yml forces DATA_DIR=/data (the mounted
# volume) and ignores this value — so the data persists across rebuilds.
DATA_DIR=./data
